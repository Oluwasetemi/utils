{
  "name": "@setemiojo/utils",
  "type": "module",
  "version": "0.0.5-beta.1",
  "packageManager": "pnpm@10.31.0",
  "description": "Opinionated collection of common JavaScript / TypeScript utils by @oluwasetemi forked from @antfu/utils",
  "author": "Oluwasetemi Ojo <setemiojo@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/oluwasetemi/utils#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oluwasetemi/utils.git"
  },
  "bugs": {
    "url": "https://github.com/oluwasetemi/utils/issues"
  },
  "keywords": [
    "utils"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "unbuild",
    "dev": "unbuild --stub",
    "lint": "eslint .",
    "lint-fix": "nr lint --fix",
    "prepublishOnly": "pnpm run build",
    "release": "bumpp",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@antfu/ni": "^28.3.0",
    "@setemiojo/eslint-config": "5.4.3",
    "@types/node": "^25.3.5",
    "@types/throttle-debounce": "^5.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "p-limit": "^7.3.0",
    "temporal-polyfill": "^0.3.0",
    "throttle-debounce": "5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "unbuild": "^3.6.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
